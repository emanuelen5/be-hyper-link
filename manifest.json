{
  "manifest_version": 2,
  "name": "hyper-Link",
  "version": "0.1.0",
  "description": "Navigate links using only the keyboard",
  "icons": { "48": "icons/icon-48.svg", "96": "icons/icon-96.svg" },
  "browser_specific_settings": {
    "gecko": {
      "id": "hyper-link@cedernaes.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "hyper-Link settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["src/background/index.ts"]
  }
}
